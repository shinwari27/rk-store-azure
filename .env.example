# ─────────────────────────────────────────────────────────────────────────────
# RK Store — Local Development Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit real secrets to GitHub.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Azure Key Vault ───────────────────────────────────────────────────────────
# Point to your deployed Key Vault (created in Stage 1).
# Run `az login` locally — DefaultAzureCredential will use your CLI session.
KEY_VAULT_URI=https://your-keyvault-name.vault.azure.net/

# ── Fallback secrets (only used if Key Vault is unreachable locally) ──────────
DJANGO_SECRET_KEY=replace-with-a-strong-random-key
DB_SERVER=your-sql-server.database.windows.net
DB_NAME=rk-store-db
DB_USERNAME=sqladmin
DB_PASSWORD=YourStrongPassword123!
APPINSIGHTS_CONNECTION_STR=InstrumentationKey=...

# ── CORS (add your frontend origin) ──────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Azure Communication Services (Stage 6) ───────────────────────────────────
ACS_EMAIL_CONNECTION_STR=endpoint=https://...
ACS_SMS_CONNECTION_STR=endpoint=https://...
ACS_SENDER_EMAIL=DoNotReply@your-acs-domain.azurecomm.net
ACS_SENDER_PHONE=+1xxxxxxxxxx
